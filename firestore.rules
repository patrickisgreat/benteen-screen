rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if request.auth.uid == userId;
    }

    // Admin role is granted out-of-band (console/privileged backend) only.
    match /roles/{userId} {
      allow read: if request.auth.uid == userId;
      allow write: if false;
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /suggestions/{suggestionId} {
        allow read: if isAuthenticated();

        // You may only create a suggestion as yourself, starting from a clean slate.
        allow create: if isAuthenticated()
          && request.resource.data.userReference == /databases/$(database)/documents/users/$(request.auth.uid)
          && request.resource.data.votesCount == 0
          && request.resource.data.deleted == false;

        // Admins may moderate (toggle `deleted`). Everyone else may only cast a
        // vote: the movie and author stay fixed, the deleted flag can't change,
        // and the vote count may move by at most one (Product Invariant 3).
        allow update: if isAuthenticated()
          && request.resource.data.suggestedItem == resource.data.suggestedItem
          && request.resource.data.userReference == resource.data.userReference
          && (
            isAdmin()
            || (
              request.resource.data.deleted == resource.data.deleted
              && request.resource.data.votesCount >= resource.data.votesCount - 1
              && request.resource.data.votesCount <= resource.data.votesCount + 1
            )
          );

        // Only the suggestion's author may hard-delete it.
        allow delete: if get(resource.data.userReference).data.uid == request.auth.uid;
      }
    }
  }
}
