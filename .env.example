# ----------------------------------------------------------------------------
# Firebase web config — PUBLIC by design (safe to ship to the browser; access is
# protected by Firestore Security Rules, not by secrecy). Maps to
# runtimeConfig.public.firebase.* by shape. Get these from the Firebase console:
# Project settings → General → Your apps → SDK setup and configuration.
# ----------------------------------------------------------------------------
NUXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NUXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
NUXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# ----------------------------------------------------------------------------
# TMDB — SERVER-ONLY. Never exposed to the browser; used only by server/api routes.
# Maps to runtimeConfig.tmdbApiKey. Get one at https://www.themoviedb.org/settings/api
# ----------------------------------------------------------------------------
NUXT_TMDB_API_KEY=your-tmdb-api-key
