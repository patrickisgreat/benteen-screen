# ----------------------------------------------------------------------------
# Supabase — from your project dashboard: Settings → API.
# URL + anon (public) key. The anon key is safe in the browser; Row Level
# Security is the authorization boundary, not secrecy.
# ----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key

# Service-role / secret key — SERVER-ONLY, never exposed to the browser. Used by
# the account-deletion API route (server/api/account/delete). Keep this secret.
NUXT_SUPABASE_SECRET_KEY=your-service-role-key

# ----------------------------------------------------------------------------
# TMDB — SERVER-ONLY. Never exposed to the browser; used only by server/api routes.
# Maps to runtimeConfig.tmdbApiKey. Get one at https://www.themoviedb.org/settings/api
# ----------------------------------------------------------------------------
NUXT_TMDB_API_KEY=your-tmdb-api-key
